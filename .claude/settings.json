{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(yarn test:frontend*)",
      "Bash(yarn lint:fix*)",
      "Bash(npx eslint:*)",
      "Bash(npx tsc:*)"
    ],
    "deny": ["Bash(rm -rf *)", "Bash(curl *)", "Read(./.env)", "Read(./.env.*)"]
  }
}
